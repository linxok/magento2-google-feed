<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_Backend::stores">
                    <resource id="Magento_Backend::stores_settings">
                        <resource id="Magento_Config::config">
                            <resource id="MyCompany_GoogleFeed::config" title="Google Feed Configuration" sortOrder="50" />
                        </resource>
                    </resource>
                </resource>
                <resource id="MyCompany_GoogleFeed::googlefeed" title="Google Feed" sortOrder="10">
                    <resource id="MyCompany_GoogleFeed::feed_view" title="View Feed" sortOrder="10" />
                    <resource id="MyCompany_GoogleFeed::feed_generate" title="Generate Feed" sortOrder="20" />
                    <resource id="MyCompany_GoogleFeed::taxonomy_import" title="Import Google Taxonomy" sortOrder="30" />
                </resource>
            </resource>
        </resources>
    </acl>
</config>
