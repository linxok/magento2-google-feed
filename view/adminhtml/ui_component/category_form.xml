<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <fieldset name="display_settings">
        <field name="mycompany_google_product_category" sortOrder="50" formElement="input" component="MyCompany_GoogleFeed/js/form/element/google-category-tree">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="source" xsi:type="string">category</item>
                    <item name="pickerUrl" xsi:type="url" path="googlefeed/category/picker"/>
                    <item name="elementTmpl" xsi:type="string">MyCompany_GoogleFeed/form/element/google-category-picker</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Google Product Category</label>
                <dataScope>mycompany_google_product_category</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">false</rule>
                </validation>
            </settings>
        </field>
    </fieldset>
</form>
